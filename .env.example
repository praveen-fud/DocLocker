# ═══════════════════════════════════════════════════════
# AbroadDocs — Environment Variables
# Copy this file to .env and fill in values
# ═══════════════════════════════════════════════════════

# ── Apps Script Web App URL (REQUIRED for Drive uploads) ──
VITE_APPS_SCRIPT_URL=

# ── Google Drive root folder ID (for "Open Drive" button in admin) ──
VITE_GOOGLE_DRIVE_FOLDER_ID=

# ── Super Admin password — sees ALL students ──
VITE_SUPER_ADMIN_PASSWORD=

# ── Advisor passwords — each advisor sees only their own students ──
VITE_ADVISOR_SAINATH_PASSWORD=
VITE_ADVISOR_SHRAVAN_PASSWORD=
