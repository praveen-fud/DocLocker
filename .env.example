# ═══════════════════════════════════════════════════════
# AbroadDocs — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════

# ── Apps Script Web App URL (REQUIRED for Drive uploads) ──
# See apps-script/Code.gs for setup instructions
VITE_APPS_SCRIPT_URL=

# ── Admin Dashboard Password ──
VITE_ADMIN_PASSWORD=

# ── (Optional) Direct Drive folder link for admin "Open Drive" button ──
VITE_GOOGLE_DRIVE_FOLDER_ID=
